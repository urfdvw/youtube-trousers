{
  "manifest_version": 3,
  "name": "YouTube Trousers",
  "version": "1.0.0",
  "description": "Hides everything related to YouTube Shorts: the Shorts button, Shorts pages, and any Shorts in feeds, search, and recommendations.",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": ["declarativeNetRequest"],
  "host_permissions": [
    "*://youtube.com/*",
    "*://www.youtube.com/*",
    "*://m.youtube.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "block-shorts-urls",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://www.youtube.com/*",
        "*://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ]
}
